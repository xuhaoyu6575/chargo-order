# 复制本文件为 deploy.env 后填写（deploy.env 勿提交 Git）
#   copy deploy.env.example deploy.env   （Windows）
#   cp deploy.env.example deploy.env     （Mac/Linux）

# 必填：ACR 登录域名（按控制台「公网访问」地址，不要末尾斜杠）
ACR_REGISTRY=registry.cn-hangzhou.aliyuncs.com

# 必填：ACR 里的命名空间（不是 K8s 命名空间）
ACR_NAMESPACE=你的ACR命名空间

# 必填：镜像标签，例如 1.0.0
IMAGE_TAG=1.0.0

# 可选：私有仓库自动 docker login + 创建集群拉镜像 Secret（填 1 开启）
WITH_PULL_SECRET=0

# 可选：与 WITH_PULL_SECRET=1 时配合使用（也可用命令行登录后仍设 WITH_PULL_SECRET=0 仅手工建 Secret）
ACR_USERNAME=
ACR_PASSWORD=
